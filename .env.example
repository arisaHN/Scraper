DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

POSTGRES_USER=scraper
POSTGRES_PASSWORD=scraper
POSTGRES_DB=scraper_db

BV_PASSKEY_DOUGLAS=your_passkey_here
BV_LOCALE_DOUGLAS=it_IT

SEPHORA_ENABLED=1

NOTINO_ENABLED=0  # set to 1 to enable notino.it scraping
# Hash of Notino's Apollo Persisted Query for getReviews. Only set this if the API starts
# returning errors (Notino redeployed their bundle) — recapture from DevTools Network tab
# (look for the sha256Hash field in the POST body to /api/product/).
# NOTINO_REVIEWS_HASH=9b49406d4f6df65fb02600d8ef3194612a78b86b984d4b18aff31e0d5c85fa0b
# Hash of sephora.it's "getReviews" Next.js Server Action. Only needed if requests start
# coming back as HTML instead of the expected RSC stream (Sephora redeployed the bundle) —
# recapture the `next-action` header value from DevTools and set it here.
# SEPHORA_NEXT_ACTION_ID=7c17146d57784229b528b62e1d5fbd1c918c08fee3

MARIONNAUD_ENABLED=0  # set to 1 to enable marionnaud.it scraping
# PowerReviews account credentials for marionnaud.it, scraped from a config blob embedded
# in the homepage. Only set these if review fetches start 404ing (Marionnaud rotated their
# PowerReviews account) — recapture powerreviews.merchant.id.it_IT/apikey.it_IT from the
# homepage's embedded JS config.
# MARIONNAUD_MERCHANT_ID=1598157158
# MARIONNAUD_APIKEY=3ab6644d-ed6b-413c-be19-01749f0af7b5

SENSATION_ENABLED=0  # set to 1 to enable sensationprofumerie.it scraping

DITANO_ENABLED=0  # set to 1 to enable ditano.com scraping
# DITANO_SHOP_DOMAIN=ditano.myshopify.com

PINALLI_ENABLED=0  # set to 1 to enable pinalli.it scraping
# Overrides for Pinalli's discovery sources — only needed if these rotate.
# PINALLI_PRODUCTS_BASE=https://pinalli-headless-prod.myshopify.com
# PINALLI_SHOP_DOMAIN=pinalli-headless-prod.myshopify.com
# PINALLI_ALGOLIA_APP=VN9XEZ6ACP
# PINALLI_ALGOLIA_KEY=<algolia search-only key>
# PINALLI_ALGOLIA_INDEX=headless_products

PRIMOR_ENABLED=0  # set to 1 to enable it.primor.eu scraping

SCRAPE_DELAY_MIN=0.5
SCRAPE_DELAY_MAX=2.0
